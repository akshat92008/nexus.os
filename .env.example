# ──────────────────────────────────────────────────────────────────────────────
# NEXUS OS — ENVIRONMENT CONFIGURATION (.env)
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values below.
# This file defines the core infrastructure, AI logic, and persistence layers.

# ── CORE SERVICE SETTINGS ────────────────────────────────────────────────────

# The environment the system is running in. Use 'production' for cloud deployment.
# Required | Service: Node.js Runtime
NODE_ENV=development

# The port the API server will listen on.
# Optional (Default: 3001) | Service: API
PORT=3001

# ── AI & REASONING (GROQ) ───────────────────────────────────────────────────
# Get your API key at: https://console.groq.com/keys
# Required | Service: Groq Cloud (Llama 3.1 70B / 8B)
# This powers the agent thinking, mission planning, and synthesis logic.
GROQ_API_KEY=gsk_...

# ── PRIMARY LLM ROUTING (OPENROUTER) ────────────────────────────────────────
# Free at: https://openrouter.ai — sign up and generate a key
# This is now the PRIMARY reasoning engine for all agents.
# It rotates through free models: DeepSeek-R1, Llama-3.3-70B, Qwen-72B
# GROQ_API_KEY above is used as a fallback only.
OPENROUTER_API_KEY=sk-or-...

# ── ADDITIONAL REASONING PROVIDERS ──────────────────────────────────────────
# Optional: used as specialized providers or emergency fallbacks.
GEMINI_API_KEY=...
ANTHROPIC_API_KEY=...

# ── VECTOR MEMORY (OPENROUTER EMBEDDINGS) ─────────────────────────────────
# Free at: https://openrouter.ai — sign up and generate a key
# Primary MVP embedding provider for semantic memory search.
# Optional: if left unset, vector indexing will be disabled in the API.
# Uses the same OPENROUTER_API_KEY as above.

# ── WEB SEARCH (SERPER.DEV) ─────────────────────────────────────────────────
# Free tier: 2,500 searches at https://serper.dev
# Required for the Researcher agent to find real data.
SERPER_API_KEY=...

# ── EMAIL SENDING (RESEND) ───────────────────────────────────────────────────
# Free tier: 3,000 emails/month at https://resend.com
# Required for the email action tool to send real emails.
RESEND_API_KEY=re_...

# ── ALLOWED ORIGINS (CORS) ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, replace with your actual Vercel URL.
ALLOWED_ORIGINS=http://localhost:3000

# ── PERSISTENCE & DATABASE (SUPABASE) ────────────────────────────────────────
# Get these at: https://supabase.com/dashboard/project/_/settings/api
# Required | Service: Supabase (PostgreSQL + Auth)
# Powers the Mission Store, Artifact Persistence, and User States.

# Your Supabase Project URL (e.g., https://xyz.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (⚠️ INTERNAL USE ONLY - Bypasses RLS). 
# Used by the API to manage missions and transactions.
SUPABASE_SERVICE_KEY=your-service-role-key

# Public Anon Key (Used by the web frontend for client-side auth).
SUPABASE_ANON_KEY=your-anon-key

# ── ORCHESTRATION & QUEUE (REDIS) ───────────────────────────────────────────
# Required | Service: Redis (Standard or Upstash)
# Powering BullMQ for reliable task execution and mission waves.
# Get a managed Redis at: https://render.com or https://upstash.com
REDIS_URL=redis://localhost:6379

# ── OPTIONAL: SANDBOX & CODE EXECUTION (E2B) ────────────────────────────────
# Get your key at: https://e2b.dev/docs
# Optional | Service: E2B Sandbox
# Enables the 'Coder' agent to execute Python/Node.js code in secure sandboxes.
E2B_API_KEY=e2b_...

# ── STRIPE (BILLING) ─────────────────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
# Required for credit top-ups. Without these, /billing shows a config error.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create one-time payment prices in Stripe Dashboard
# Set the unit_amount to 500, 2000, 5000 (cents) for $5, $20, $50
STRIPE_PRICE_5USD=price_...
STRIPE_PRICE_20USD=price_...
STRIPE_PRICE_50USD=price_...

# The public URL for the agent to use (e.g., Cloud Run URL)
RUNWAY_GUARDIAN_URL=https://...

# The persistent Stripe checkout link
STRIPE_CHECKOUT_URL=https://buy.stripe.com/...

# Frontend env vars (prefix NEXT_PUBLIC_ so Next.js exposes them to the browser)
NEXT_PUBLIC_STRIPE_PRICE_5USD=price_...
NEXT_PUBLIC_STRIPE_PRICE_20USD=price_...
NEXT_PUBLIC_STRIPE_PRICE_50USD=price_...
\nLOG_LEVEL=info

# ── OPENCLAW-INSPIRED SKILLS (OPTIONAL) ──────────────────────────────────────

# GitHub CLI authentication token
# Required for github skill. Install gh CLI first: https://cli.github.com
# Then run: gh auth login
GH_TOKEN=ghp_...

# Notion API integration token
# Create at: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_...

# Google Calendar / Apple Calendar
# Uses AppleScript on macOS for local calendar access
# No additional API key needed - requires macOS and Calendar app permissions
GOOGLE_CALENDAR_API_KEY=...  # Optional: for Google Calendar API instead of local

# Browser Automation (Puppeteer)
# Install: pnpm add puppeteer
# No env var needed, but ensure Chrome/Chromium is available

# ── OPENAI EMBEDDINGS (SEMANTIC MEMORY) ──────────────────────────────────────
# Optional: for vector search in semantic memory
# Uses text-embedding-3-small model
OPENAI_API_KEY=sk-...

# ── DISCORD BOT TOKEN ────────────────────────────────────────────────────────
# Required for Discord channel adapter
# Create bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=...

# ── TELEGRAM BOT TOKEN ───────────────────────────────────────────────────────
# Required for Telegram channel adapter
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=...

# ── SLACK BOT TOKEN ─────────────────────────────────────────────────────────
# Required for Slack channel adapter
# Create app at: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ── EMAIL / SMTP ────────────────────────────────────────────────────────────
# For email channel adapter
# Configure IMAP host, SMTP host, username, password
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=...
EMAIL_PASSWORD=...  # Use app-specific password for Gmail
EMAIL_TLS=true

# ── TWILIO SMS ────────────────────────────────────────────────────────────────
# Optional for SMS channel adapter fallback (when not using macOS Messages)
TWILIO_SID=...
TWILIO_TOKEN=...
TWILIO_PHONE=...

# ── TRELLO ───────────────────────────────────────────────────────────────────
# Required for Trello skill
# Get at: https://trello.com/power-ups/admin/
TRELLO_API_KEY=...
TRELLO_TOKEN=...

# ── TENOR GIF SEARCH ───────────────────────────────────────────────────────
# Optional for gifgrep skill. Free tier available.
# Get at: https://developers.google.com/tenor/guides/quickstart
TENOR_API_KEY=...

# ── PHILIPS HUE ────────────────────────────────────────────────────────────
# Optional for Hue smart home skill
# Find bridge IP via: https://discovery.meethue.com/
HUE_BRIDGE_IP=192.168.1.xxx
# Create API key: press link button, then POST to /api with {"devicetype":"nexus-os"}
HUE_API_KEY=...

# ── STABILITY AI ────────────────────────────────────────────────────────────
# Optional for image generation with Stability AI
STABILITY_API_KEY=sk-...

# ── SUNO MUSIC ───────────────────────────────────────────────────────────────
# Optional for music generation
# Suno API requires early access signup
SUNO_API_KEY=...

# ── SIGNAL MESSENGER ──────────────────────────────────────────────────────────
# Optional for Signal channel adapter
# Requires signald daemon: https://signald.org
SIGNALD_SOCKET=/var/run/signald/signald.sock
SIGNAL_ACCOUNT=+

# ── MATRIX ────────────────────────────────────────────────────────────────────
# Optional for Matrix channel adapter
# Get access token: https://matrix.org/docs/develop/client-api/
MATRIX_HOMESERVER=https://matrix.org
MATRIX_ACCESS_TOKEN=syt_...
MATRIX_USER_ID=@bot:matrix.org

# ── GOOGLE INTEGRATIONS ───────────────────────────────────────────────────────
# OAuth 2.0 credentials for Gmail + Calendar
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3006/api/integrations/google/callback

# ── HUBSPOT CRM ──────────────────────────────────────────────────────────────
# Private app token from https://app.hubspot.com/private-apps
HUBSPOT_API_KEY=pat-na1-...
HUBSPOT_CLIENT_ID=your-hubspot-app-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-app-client-secret
HUBSPOT_REDIRECT_URI=http://localhost:3001/api/integrations/hubspot/callback

# ── NOTION ───────────────────────────────────────────────────────────────────
# Integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# ── SLACK ────────────────────────────────────────────────────────────────────
# Bot User OAuth Token (xoxb-) from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...

# ── GITHUB ───────────────────────────────────────────────────────────────────
# Personal access token from https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ── ANTHROPIC (Claude) ───────────────────────────────────────────────────────
# API key for LLM Router (used by intent classification + reasoning)
ANTHROPIC_API_KEY=sk-ant-...

# ── NEXUS LOCALE ────────────────────────────────────────────────────────────
# Default language for i18n: en, es, fr, de, it, pt, ja, ko, zh, ar, hi, ru
NEXUS_LOCALE=en
