# ──────────────────────────────────────────────────────────────────────────────
# NEXUS OS — ENVIRONMENT CONFIGURATION (.env)
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values below.
# This file defines the core infrastructure, AI logic, and persistence layers.

# ── CORE SERVICE SETTINGS ────────────────────────────────────────────────────

# The environment the system is running in. Use 'production' for cloud deployment.
# Required | Service: Node.js Runtime
NODE_ENV=development

# The port the API server will listen on.
# Optional (Default: 3001) | Service: API
PORT=3001

# ── AI & REASONING (GROQ) ───────────────────────────────────────────────────
# Get your API key at: https://console.groq.com/keys
# Required | Service: Groq Cloud (Llama 3.1 70B / 8B)
# This powers the agent thinking, mission planning, and synthesis logic.
GROQ_API_KEY=gsk_...

# ── PERSISTENCE & DATABASE (SUPABASE) ────────────────────────────────────────
# Get these at: https://supabase.com/dashboard/project/_/settings/api
# Required | Service: Supabase (PostgreSQL + Auth)
# Powers the Mission Store, Artifact Persistence, and User States.

# Your Supabase Project URL (e.g., https://xyz.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (⚠️ INTERNAL USE ONLY - Bypasses RLS). 
# Used by the API to manage missions and transactions.
SUPABASE_SERVICE_KEY=your-service-role-key

# Public Anon Key (Used by the web frontend for client-side auth).
SUPABASE_ANON_KEY=your-anon-key

# ── ORCHESTRATION & QUEUE (REDIS) ───────────────────────────────────────────
# Required | Service: Redis (Standard or Upstash)
# Powering BullMQ for reliable task execution and mission waves.
# Get a managed Redis at: https://render.com or https://upstash.com
REDIS_URL=redis://localhost:6379

# ── OPTIONAL: SANDBOX & CODE EXECUTION (E2B) ────────────────────────────────
# Get your key at: https://e2b.dev/docs
# Optional | Service: E2B Sandbox
# Enables the 'Coder' agent to execute Python/Node.js code in secure sandboxes.
E2B_API_KEY=e2b_...
