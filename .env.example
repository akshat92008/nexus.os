# ══════════════════════════════════════════════════════════════════
#  Nexus OS — Environment Variables
#  Copy this file to .env in both apps/api/ and apps/web/
# ══════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── API Server ────────────────────────────────────────────────────
PORT=3001
# Restrict CORS to your frontend origin in production:
CORS_ORIGIN=http://localhost:3000

# ── Supabase (optional — falls back to in-memory if not set) ──────
# Get these from your Supabase project: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Frontend (apps/web/.env.local) ────────────────────────────────
# Points the Next.js app to the Express API
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Supabase DDL (run once in your Supabase SQL editor) ───────────
