{
  "name": "@nexus-os/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=2048\" tsx src/index.ts",
    "bin": "./dist/index.js",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_OPTIONS=\"--max-old-space-size=2048\" node dist/index.js",
    "worker": "node dist/workers/taskWorker.js",
    "mission-worker": "node dist/workers/missionWorker.js",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest watch",
    "migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@e2b/code-interpreter": "^2.4.0",
    "@nexus-os/types": "workspace:*",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "bullmq": "^5.73.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "e2b": "^2.19.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "openai": "^6.33.0",
    "opossum": "^8.1.0",
    "pino": "^9.3.2",
    "uuid": "^10.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/opossum": "^8.1.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.23.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}