{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@nexus-os/types": ["../types/index.ts"]
    }
  },
  "include": ["src/**/*", "../types/index.ts"],
  "exclude": ["node_modules", "dist", "src/__tests__", "src/__mocks__"]
}
