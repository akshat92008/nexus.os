# apps/api/.env.example
NODE_ENV=development
PORT=3006

# Supabase (get from supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# AI Providers (at least GROQ_API_KEY is required)
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
GEMINI_API_KEY=AI...
NVIDIA_API_KEY=nvapi-...

# Email (one of the two is required in production)
SENDGRID_API_KEY=SG....
RESEND_API_KEY=re_...
EMAIL_FROM_ADDRESS=hello@yourdomain.com
EMAIL_FROM_NAME=Your Name

# CORS (comma-separated list of allowed frontend origins)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Feature flags
USE_AI_PROXY=true
STORAGE_STRATEGY=supabase

# Optional
REDIS_URL=redis://localhost:6379
E2B_API_KEY=
SERPER_API_KEY=
