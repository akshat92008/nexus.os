NODE_ENV=production
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# PRIMARY LLM — free at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# EMBEDDINGS only — free at https://aistudio.google.com
GEMINI_API_KEY=

# OPTIONAL fallback — free at https://console.groq.com
GROQ_API_KEY=

APP_URL=http://localhost:3000

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Optional — if set, the rate limit governor becomes distributed-safe across multiple instances 
# REDIS_URL=redis://localhost:6379 
REDIS_URL=
E2B_API_KEY=

# Section 2: Real-World Integrations
SERPER_API_KEY=        # Get at https://serper.dev
RESEND_API_KEY=        # Get at https://resend.com
GITHUB_TOKEN=          # GitHub PAT with repo scope
TAVILY_API_KEY=        # Get free key at https://tavily.com 

# ── FRONTEND (Next.js public vars) ────────────────────────────────────────── 
# Same values as SUPABASE_URL and SUPABASE_ANON_KEY above — required by web app 
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co 
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key 
NEXT_PUBLIC_API_URL=https://your-render-api.onrender.com 
 
# ── CORS ───────────────────────────────────────────────────────────────────── 
# Comma-separated list of allowed frontend origins 
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app 
