NODE_ENV=production
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

OPENROUTER_API_KEY=    # Get at https://openrouter.ai/keys
APP_URL=http://localhost:3000

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
REDIS_URL=
E2B_API_KEY=
GEMINI_API_KEY=    # FREE at https://aistudio.google.com/app/apikey (used for embeddings)

# Section 2: Real-World Integrations
SERPER_API_KEY=        # Get at https://serper.dev
RESEND_API_KEY=        # Get at https://resend.com
GITHUB_TOKEN=          # GitHub PAT with repo scope
TAVILY_API_KEY=        # Alternative search (optional)

# ── FRONTEND (Next.js public vars) ────────────────────────────────────────── 
# Same values as SUPABASE_URL and SUPABASE_ANON_KEY above — required by web app 
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co 
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key 
NEXT_PUBLIC_API_URL=https://your-render-api.onrender.com 
 
# ── CORS ───────────────────────────────────────────────────────────────────── 
# Comma-separated list of allowed frontend origins 
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app 
 
# ── SEARCH (Tavily) ─────────────────────────────────────────────────────────── 
# Get free key at https://tavily.com 
TAVILY_API_KEY=tvly-... 
 
# ── EMBEDDINGS (OpenAI) ────────────────────────────────────────────────────── 
# Used by VectorStore for semantic memory. Get at https://platform.openai.com 
OPENAI_API_KEY=sk-...
