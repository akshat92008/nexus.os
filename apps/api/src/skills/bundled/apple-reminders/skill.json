{
  "id": "apple-reminders",
  "name": "Apple Reminders",
  "version": "1.0.0",
  "description": "Create, list, and manage Apple Reminders on macOS via AppleScript",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "reminders_create",
      "name": "apple_reminders_create",
      "description": "Create a new reminder",
      "parameters": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Reminder name" },
          "list": { "type": "string", "description": "List name", "default": "Reminders" },
          "due_date": { "type": "string", "description": "Due date (ISO 8601 or natural language)" },
          "notes": { "type": "string", "description": "Notes/notes" },
          "priority": { "type": "string", "description": "Priority: low, medium, high" }
        },
        "required": ["name"]
      },
      "handler": "handlers/create.js",
      "returnType": "object"
    },
    {
      "id": "reminders_list",
      "name": "apple_reminders_list",
      "description": "List reminders in a list",
      "parameters": {
        "type": "object",
        "properties": {
          "list": { "type": "string", "description": "List name", "default": "Reminders" },
          "completed": { "type": "boolean", "description": "Show completed?", "default": false }
        }
      },
      "handler": "handlers/list.js",
      "returnType": "object"
    },
    {
      "id": "reminders_complete",
      "name": "apple_reminders_complete",
      "description": "Mark a reminder as completed",
      "parameters": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Reminder name to complete" },
          "list": { "type": "string", "description": "List name", "default": "Reminders" }
        },
        "required": ["name"]
      },
      "handler": "handlers/complete.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": false, "shell": true, "envVars": [] },
  "metadata": { "tags": ["macos", "reminders", "tasks"], "category": "productivity", "icon": "check-circle", "color": "#ff9500" }
}
