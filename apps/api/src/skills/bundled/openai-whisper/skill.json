{
  "id": "openai-whisper",
  "name": "OpenAI Whisper",
  "version": "1.0.0",
  "description": "Speech-to-text transcription using OpenAI Whisper API",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "whisper_transcribe",
      "name": "whisper_transcribe",
      "description": "Transcribe an audio file to text",
      "parameters": {
        "type": "object",
        "properties": {
          "audio_path": { "type": "string", "description": "Path to audio file (mp3, mp4, mpeg, mpga, m4a, wav, webm)" },
          "model": { "type": "string", "description": "Whisper model", "enum": ["whisper-1"], "default": "whisper-1" },
          "language": { "type": "string", "description": "Language code (optional)" },
          "prompt": { "type": "string", "description": "Optional prompt for context" }
        },
        "required": ["audio_path"]
      },
      "handler": "handlers/transcribe.js",
      "returnType": "object"
    },
    {
      "id": "whisper_translate",
      "name": "whisper_translate",
      "description": "Translate audio to English text",
      "parameters": {
        "type": "object",
        "properties": {
          "audio_path": { "type": "string", "description": "Path to audio file" }
        },
        "required": ["audio_path"]
      },
      "handler": "handlers/translate.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": ["/tmp/*"], "network": true, "shell": false, "envVars": ["OPENAI_API_KEY"] },
  "metadata": { "tags": ["speech", "transcription", "ai"], "category": "media", "icon": "mic", "color": "#A78BFA" }
}
