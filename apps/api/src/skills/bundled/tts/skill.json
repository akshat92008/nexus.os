{
  "id": "tts",
  "name": "Text to Speech",
  "version": "1.0.0",
  "description": "Text-to-speech using OpenAI TTS or macOS say command",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "tts_speak",
      "name": "tts_speak",
      "description": "Convert text to speech and speak aloud",
      "parameters": {
        "type": "object",
        "properties": {
          "text": { "type": "string", "description": "Text to speak" },
          "voice": { "type": "string", "description": "Voice (macOS: Alex, Samantha, etc. OpenAI: alloy, echo, fable, onyx, nova, shimmer)", "default": "Alex" },
          "speed": { "type": "number", "description": "Speaking speed", "default": 1.0 },
          "provider": { "type": "string", "enum": ["macos", "openai"], "default": "macos" },
          "output_path": { "type": "string", "description": "Save to file path instead of speaking (OpenAI only)" }
        },
        "required": ["text"]
      },
      "handler": "handlers/speak.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": ["/tmp/*"], "network": true, "shell": true, "envVars": ["OPENAI_API_KEY"] },
  "metadata": { "tags": ["speech", "tts", "audio"], "category": "media", "icon": "volume-2", "color": "#10B981" }
}
