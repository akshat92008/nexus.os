{
  "id": "coding-agent",
  "name": "Coding Agent",
  "version": "1.0.0",
  "description": "Code analysis, linting, refactoring, and execution helpers",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "code_lint",
      "name": "code_lint",
      "description": "Lint code files (ESLint, prettier, flake8, etc.)",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "File or directory path" },
          "linter": { "type": "string", "description": "Linter name: eslint, prettier, flake8, shellcheck", "default": "eslint" },
          "fix": { "type": "boolean", "description": "Auto-fix issues", "default": false }
        },
        "required": ["path"]
      },
      "handler": "handlers/lint.js",
      "returnType": "object"
    },
    {
      "id": "code_format",
      "name": "code_format",
      "description": "Format code files",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "File or directory path" },
          "formatter": { "type": "string", "description": "Formatter: prettier, black, gofmt", "default": "prettier" }
        },
        "required": ["path"]
      },
      "handler": "handlers/format.js",
      "returnType": "object"
    },
    {
      "id": "code_analyze",
      "name": "code_analyze",
      "description": "Analyze code complexity and quality",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "File or directory path" }
        },
        "required": ["path"]
      },
      "handler": "handlers/analyze.js",
      "returnType": "object"
    },
    {
      "id": "code_git_diff",
      "name": "code_git_diff",
      "description": "Get git diff for a file or staged changes",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "File path or empty for all staged" },
          "staged": { "type": "boolean", "description": "Show staged changes only", "default": true }
        }
      },
      "handler": "handlers/git_diff.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": false, "shell": true, "envVars": [] },
  "metadata": { "tags": ["code", "lint", "format", "git"], "category": "development", "icon": "code", "color": "#8B5CF6" }
}
