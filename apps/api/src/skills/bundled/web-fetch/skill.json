{
  "id": "web-fetch",
  "name": "Web Fetch",
  "version": "1.0.0",
  "description": "Fetch and parse web pages, convert to Markdown, extract structured data",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "fetch_page",
      "name": "webfetch_page",
      "description": "Fetch a webpage and return raw HTML or text",
      "parameters": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "URL to fetch" },
          "format": { "type": "string", "enum": ["html", "text", "markdown", "json"], "default": "text" },
          "headers": { "type": "object", "description": "Custom HTTP headers" },
          "timeout": { "type": "number", "description": "Timeout in ms", "default": 15000 }
        },
        "required": ["url"]
      },
      "handler": "handlers/fetch.js",
      "returnType": "object"
    },
    {
      "id": "fetch_rss",
      "name": "webfetch_rss",
      "description": "Fetch and parse an RSS/Atom feed",
      "parameters": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "Feed URL" },
          "limit": { "type": "number", "description": "Max items", "default": 20 }
        },
        "required": ["url"]
      },
      "handler": "handlers/rss.js",
      "returnType": "object"
    },
    {
      "id": "fetch_json",
      "name": "webfetch_json",
      "description": "Fetch JSON data from an API",
      "parameters": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "API URL" },
          "method": { "type": "string", "enum": ["GET", "POST", "PUT", "DELETE"], "default": "GET" },
          "body": { "type": "object", "description": "Request body (for POST/PUT)" },
          "headers": { "type": "object", "description": "Custom headers" }
        },
        "required": ["url"]
      },
      "handler": "handlers/json.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": true, "shell": false, "envVars": [] },
  "metadata": { "tags": ["web", "fetch", "scraper", "api"], "category": "web", "icon": "globe", "color": "#2196F3" }
}
