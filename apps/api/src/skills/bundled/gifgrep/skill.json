{
  "id": "gifgrep",
  "name": "GIF Grep",
  "version": "1.0.0",
  "description": "Search GIFs from Tenor or Giphy",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "gif_search",
      "name": "gifgrep_search",
      "description": "Search for a GIF",
      "parameters": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Search query" },
          "limit": { "type": "number", "description": "Max results", "default": 10 },
          "provider": { "type": "string", "enum": ["tenor", "giphy"], "default": "tenor" }
        },
        "required": ["query"]
      },
      "handler": "handlers/search.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": true, "shell": false, "envVars": [] },
  "metadata": { "tags": ["gif", "search", "media"], "category": "media", "icon": "image", "color": "#FF6B6B" }
}
