{
  "id": "wacli",
  "name": "Wi-Fi Manager",
  "version": "1.0.0",
  "description": "Manage Wi-Fi connections on macOS via networksetup",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "wifi_status",
      "name": "wacli_status",
      "description": "Get current Wi-Fi status",
      "parameters": { "type": "object", "properties": {} },
      "handler": "handlers/status.js",
      "returnType": "object"
    },
    {
      "id": "wifi_scan",
      "name": "wacli_scan",
      "description": "Scan for available Wi-Fi networks",
      "parameters": { "type": "object", "properties": {} },
      "handler": "handlers/scan.js",
      "returnType": "object"
    },
    {
      "id": "wifi_connect",
      "name": "wacli_connect",
      "description": "Connect to a Wi-Fi network",
      "parameters": {
        "type": "object",
        "properties": {
          "ssid": { "type": "string", "description": "Network name" },
          "password": { "type": "string", "description": "Network password (if required)" }
        },
        "required": ["ssid"]
      },
      "handler": "handlers/connect.js",
      "returnType": "object"
    },
    {
      "id": "wifi_disconnect",
      "name": "wacli_disconnect",
      "description": "Disconnect from Wi-Fi",
      "parameters": { "type": "object", "properties": {} },
      "handler": "handlers/disconnect.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": false, "shell": true, "envVars": [] },
  "metadata": { "tags": ["macos", "wifi", "network"], "category": "system", "icon": "wifi", "color": "#4CAF50" }
}
