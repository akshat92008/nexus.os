{
  "id": "imessage",
  "name": "iMessage",
  "version": "1.0.0",
  "description": "Send iMessages on macOS via AppleScript",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "imsg_send",
      "name": "imessage_send",
      "description": "Send an iMessage to a contact",
      "parameters": {
        "type": "object",
        "properties": {
          "to": { "type": "string", "description": "Phone number, email, or contact name" },
          "message": { "type": "string", "description": "Message text" }
        },
        "required": ["to", "message"]
      },
      "handler": "handlers/send.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": false, "shell": true, "envVars": [] },
  "metadata": { "tags": ["macos", "imessage", "sms"], "category": "communication", "icon": "message-circle", "color": "#34C759" }
}
