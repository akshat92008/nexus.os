{
  "id": "web_search",
  "name": "Web Search",
  "version": "1.0.0",
  "description": "Search the web for information using DuckDuckGo and other search engines",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "search_web",
      "name": "web_search",
      "description": "Search the web for information on a given query",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The search query"
          },
          "max_results": {
            "type": "number",
            "description": "Maximum number of results to return",
            "default": 5
          }
        },
        "required": ["query"]
      },
      "handler": "handlers/search_web.js",
      "returnType": "object"
    },
    {
      "id": "fetch_page",
      "name": "fetch_page",
      "description": "Fetch and extract content from a web page",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "URL to fetch"
          },
          "extract_text": {
            "type": "boolean",
            "description": "Extract main text content only",
            "default": true
          }
        },
        "required": ["url"]
      },
      "handler": "handlers/fetch_page.js",
      "returnType": "object"
    }
  ],
  "config": {
    "schema": {
      "search_engine": {
        "type": "string",
        "description": "Search engine to use",
        "default": "duckduckgo",
        "enum": ["duckduckgo", "bing", "google"]
      },
      "rate_limit_per_minute": {
        "type": "number",
        "description": "Max searches per minute",
        "default": 10
      }
    },
    "defaults": {
      "search_engine": "duckduckgo",
      "rate_limit_per_minute": 10
    }
  },
  "runtime": {
    "language": "javascript",
    "sandbox": {
      "enabled": false
    }
  },
  "dependencies": {
    "npm": {
      "axios": "^1.6.0",
      "cheerio": "^1.0.0"
    }
  },
  "permissions": {
    "filesystem": [],
    "network": true,
    "shell": false,
    "envVars": []
  },
  "metadata": {
    "tags": ["search", "web", "information"],
    "category": "productivity",
    "icon": "search",
    "color": "#3b82f6"
  }
}
