{
  "id": "music-generation",
  "name": "Music Generation",
  "version": "1.0.0",
  "description": "Generate music/audio using AI models (Suno, Udio, or local)",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "music_generate",
      "name": "music_generate",
      "description": "Generate music from text prompt",
      "parameters": {
        "type": "object",
        "properties": {
          "prompt": { "type": "string", "description": "Music description" },
          "duration": { "type": "number", "description": "Duration in seconds", "default": 30 },
          "instrumental": { "type": "boolean", "description": "Instrumental only", "default": false },
          "output_path": { "type": "string", "description": "Output file path" },
          "provider": { "type": "string", "enum": ["suno", "udio", "local"], "default": "suno" }
        },
        "required": ["prompt"]
      },
      "handler": "handlers/generate.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": ["/tmp/*"], "network": true, "shell": false, "envVars": ["SUNO_API_KEY"] },
  "metadata": { "tags": ["music", "audio", "generation", "ai"], "category": "media", "icon": "music", "color": "#8B5CF6" }
}
