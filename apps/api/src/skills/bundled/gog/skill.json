{
  "id": "gog",
  "name": "Go Game (igo / baduk)",
  "version": "1.0.0",
  "description": "Play Go (igo / baduk / weiqi) against an AI or manage board state",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "gog_new",
      "name": "gog_new_game",
      "description": "Start a new Go game",
      "parameters": {
        "type": "object",
        "properties": {
          "size": { "type": "number", "description": "Board size (9, 13, 19)", "default": 19 },
          "komi": { "type": "number", "description": "Komi (compensation points)", "default": 7.5 },
          "handicap": { "type": "number", "description": "Handicap stones", "default": 0 }
        }
      },
      "handler": "handlers/new_game.js",
      "returnType": "object"
    },
    {
      "id": "gog_move",
      "name": "gog_move",
      "description": "Play a move (pass or coordinate)",
      "parameters": {
        "type": "object",
        "properties": {
          "game_id": { "type": "string", "description": "Game ID" },
          "coordinate": { "type": "string", "description": "Coordinate like 'D4' or 'pass'" },
          "color": { "type": "string", "enum": ["black", "white"] }
        },
        "required": ["game_id", "coordinate", "color"]
      },
      "handler": "handlers/move.js",
      "returnType": "object"
    },
    {
      "id": "gog_board",
      "name": "gog_get_board",
      "description": "Get current board state",
      "parameters": {
        "type": "object",
        "properties": {
          "game_id": { "type": "string", "description": "Game ID" }
        },
        "required": ["game_id"]
      },
      "handler": "handlers/board.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": false, "shell": false, "envVars": [] },
  "metadata": { "tags": ["game", "go", "baduk", "igo"], "category": "entertainment", "icon": "circle-dot", "color": "#000000" }
}
