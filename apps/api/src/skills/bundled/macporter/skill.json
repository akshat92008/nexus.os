{
  "id": "macporter",
  "name": "macOS App Manager",
  "version": "1.0.0",
  "description": "Open, quit, focus, and manage macOS applications via AppleScript",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "mac_open",
      "name": "macporter_open",
      "description": "Open an application or file on macOS",
      "parameters": {
        "type": "object",
        "properties": {
          "app": { "type": "string", "description": "Application name (e.g. Safari, Notes, Finder)" },
          "file": { "type": "string", "description": "Optional file path to open with the app" },
          "activate": { "type": "boolean", "description": "Bring to front after opening", "default": true }
        },
        "required": ["app"]
      },
      "handler": "handlers/open.js",
      "returnType": "object"
    },
    {
      "id": "mac_quit",
      "name": "macporter_quit",
      "description": "Quit an application",
      "parameters": {
        "type": "object",
        "properties": {
          "app": { "type": "string", "description": "Application name" },
          "force": { "type": "boolean", "description": "Force quit", "default": false }
        },
        "required": ["app"]
      },
      "handler": "handlers/quit.js",
      "returnType": "object"
    },
    {
      "id": "mac_focus",
      "name": "macporter_focus",
      "description": "Activate/bring an application to the front",
      "parameters": {
        "type": "object",
        "properties": {
          "app": { "type": "string", "description": "Application name" }
        },
        "required": ["app"]
      },
      "handler": "handlers/focus.js",
      "returnType": "object"
    },
    {
      "id": "mac_list",
      "name": "macporter_list",
      "description": "List running applications",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "handler": "handlers/list.js",
      "returnType": "object"
    },
    {
      "id": "mac_minimize",
      "name": "macporter_minimize",
      "description": "Minimize an application window",
      "parameters": {
        "type": "object",
        "properties": {
          "app": { "type": "string", "description": "Application name" }
        },
        "required": ["app"]
      },
      "handler": "handlers/minimize.js",
      "returnType": "object"
    },
    {
      "id": "mac_maximize",
      "name": "macporter_maximize",
      "description": "Maximize/restore an application window",
      "parameters": {
        "type": "object",
        "properties": {
          "app": { "type": "string", "description": "Application name" }
        },
        "required": ["app"]
      },
      "handler": "handlers/maximize.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": false, "shell": true, "envVars": [] },
  "metadata": { "tags": ["macos", "apps", "window-management"], "category": "system", "icon": "monitor", "color": "#0D47A1" }
}
