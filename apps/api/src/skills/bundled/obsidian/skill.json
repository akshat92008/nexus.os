{
  "id": "obsidian",
  "name": "Obsidian Vault",
  "version": "1.0.0",
  "description": "Read, search, and manage Obsidian vault notes via local REST API or filesystem",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "obsidian_list_notes",
      "name": "obsidian_list_notes",
      "description": "List notes in an Obsidian vault",
      "parameters": {
        "type": "object",
        "properties": {
          "vault_path": { "type": "string", "description": "Path to Obsidian vault directory" },
          "folder": { "type": "string", "description": "Subfolder to list (optional)" }
        },
        "required": ["vault_path"]
      },
      "handler": "handlers/list_notes.js",
      "returnType": "object"
    },
    {
      "id": "obsidian_read_note",
      "name": "obsidian_read_note",
      "description": "Read a note by path",
      "parameters": {
        "type": "object",
        "properties": {
          "vault_path": { "type": "string", "description": "Vault path" },
          "note_path": { "type": "string", "description": "Relative path to note within vault" }
        },
        "required": ["vault_path", "note_path"]
      },
      "handler": "handlers/read_note.js",
      "returnType": "object"
    },
    {
      "id": "obsidian_write_note",
      "name": "obsidian_write_note",
      "description": "Create or overwrite a note",
      "parameters": {
        "type": "object",
        "properties": {
          "vault_path": { "type": "string", "description": "Vault path" },
          "note_path": { "type": "string", "description": "Relative path to note" },
          "content": { "type": "string", "description": "Markdown content" }
        },
        "required": ["vault_path", "note_path", "content"]
      },
      "handler": "handlers/write_note.js",
      "returnType": "object"
    },
    {
      "id": "obsidian_search",
      "name": "obsidian_search",
      "description": "Search notes by content or title",
      "parameters": {
        "type": "object",
        "properties": {
          "vault_path": { "type": "string", "description": "Vault path" },
          "query": { "type": "string", "description": "Search query" },
          "limit": { "type": "number", "description": "Max results", "default": 20 }
        },
        "required": ["vault_path", "query"]
      },
      "handler": "handlers/search.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": false, "shell": false, "envVars": [] },
  "metadata": { "tags": ["obsidian", "notes", "markdown", "pkm"], "category": "productivity", "icon": "book-open", "color": "#7C3AED" }
}
