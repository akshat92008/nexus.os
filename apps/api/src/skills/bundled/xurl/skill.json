{
  "id": "xurl",
  "name": "X URL Shortener",
  "version": "1.0.0",
  "description": "Shorten and expand URLs",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "url_shorten",
      "name": "xurl_shorten",
      "description": "Shorten a URL using TinyURL or other free services",
      "parameters": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "URL to shorten" }
        },
        "required": ["url"]
      },
      "handler": "handlers/shorten.js",
      "returnType": "object"
    },
    {
      "id": "url_expand",
      "name": "xurl_expand",
      "description": "Expand a shortened URL to its original form",
      "parameters": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "Shortened URL" }
        },
        "required": ["url"]
      },
      "handler": "handlers/expand.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": true, "shell": false, "envVars": [] },
  "metadata": { "tags": ["url", "shortener", "utility"], "category": "utility", "icon": "link", "color": "#64748B" }
}
