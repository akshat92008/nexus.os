{
  "id": "apple-notes",
  "name": "Apple Notes",
  "version": "1.0.0",
  "description": "Create, read, and manage Apple Notes on macOS via AppleScript",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "notes_create",
      "name": "apple_notes_create",
      "description": "Create a new note in Apple Notes",
      "parameters": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "description": "Note title" },
          "body": { "type": "string", "description": "Note body content" },
          "folder": { "type": "string", "description": "Folder name (default: Notes)", "default": "Notes" }
        },
        "required": ["title", "body"]
      },
      "handler": "handlers/create.js",
      "returnType": "object"
    },
    {
      "id": "notes_list",
      "name": "apple_notes_list",
      "description": "List notes in a folder",
      "parameters": {
        "type": "object",
        "properties": {
          "folder": { "type": "string", "description": "Folder name", "default": "Notes" },
          "limit": { "type": "number", "description": "Max notes to return", "default": 20 },
          "search": { "type": "string", "description": "Search query" }
        }
      },
      "handler": "handlers/list.js",
      "returnType": "object"
    },
    {
      "id": "notes_get",
      "name": "apple_notes_get",
      "description": "Get a note by title",
      "parameters": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "description": "Note title to find" },
          "folder": { "type": "string", "description": "Folder name", "default": "Notes" }
        },
        "required": ["title"]
      },
      "handler": "handlers/get.js",
      "returnType": "object"
    },
    {
      "id": "notes_delete",
      "name": "apple_notes_delete",
      "description": "Delete a note by title",
      "parameters": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "description": "Note title to delete" },
          "folder": { "type": "string", "description": "Folder name", "default": "Notes" }
        },
        "required": ["title"]
      },
      "handler": "handlers/delete.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": false, "shell": true, "envVars": [] },
  "metadata": { "tags": ["macos", "notes", "productivity"], "category": "productivity", "icon": "sticky-note", "color": "#ffd700" }
}
