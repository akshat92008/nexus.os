{
  "id": "spotify",
  "name": "Spotify Player",
  "version": "1.0.0",
  "description": "Control Spotify playback on macOS via AppleScript",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "spotify_play",
      "name": "spotify_play",
      "description": "Play Spotify track/playlist/album",
      "parameters": {
        "type": "object",
        "properties": {
          "track": { "type": "string", "description": "Track name to search and play" },
          "artist": { "type": "string", "description": "Artist name" },
          "uri": { "type": "string", "description": "Spotify URI" }
        }
      },
      "handler": "handlers/play.js",
      "returnType": "object"
    },
    {
      "id": "spotify_pause",
      "name": "spotify_pause",
      "description": "Pause Spotify",
      "parameters": { "type": "object", "properties": {} },
      "handler": "handlers/pause.js",
      "returnType": "object"
    },
    {
      "id": "spotify_next",
      "name": "spotify_next",
      "description": "Next track",
      "parameters": { "type": "object", "properties": {} },
      "handler": "handlers/next.js",
      "returnType": "object"
    },
    {
      "id": "spotify_previous",
      "name": "spotify_previous",
      "description": "Previous track",
      "parameters": { "type": "object", "properties": {} },
      "handler": "handlers/previous.js",
      "returnType": "object"
    },
    {
      "id": "spotify_now_playing",
      "name": "spotify_now_playing",
      "description": "Get currently playing track info",
      "parameters": { "type": "object", "properties": {} },
      "handler": "handlers/now_playing.js",
      "returnType": "object"
    },
    {
      "id": "spotify_volume",
      "name": "spotify_volume",
      "description": "Set volume (0-100)",
      "parameters": {
        "type": "object",
        "properties": {
          "level": { "type": "number", "description": "Volume level 0-100" }
        },
        "required": ["level"]
      },
      "handler": "handlers/volume.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {},
  "permissions": { "filesystem": [], "network": false, "shell": true, "envVars": [] },
  "metadata": { "tags": ["spotify", "music", "media"], "category": "media", "icon": "music", "color": "#1DB954" }
}
