{
  "id": "nano-pdf",
  "name": "Nano PDF",
  "version": "1.0.0",
  "description": "Extract text and metadata from PDF files",
  "author": "nexus-os",
  "source": "bundled",
  "type": "system",
  "tools": [
    {
      "id": "pdf_extract_text",
      "name": "nano_pdf_extract_text",
      "description": "Extract text content from a PDF file",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "Path to PDF file" },
          "pages": { "type": "array", "items": { "type": "number" }, "description": "Specific page numbers (1-indexed)" }
        },
        "required": ["path"]
      },
      "handler": "handlers/extract_text.js",
      "returnType": "object"
    },
    {
      "id": "pdf_metadata",
      "name": "nano_pdf_metadata",
      "description": "Get PDF metadata (title, author, pages, etc.)",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "Path to PDF file" }
        },
        "required": ["path"]
      },
      "handler": "handlers/metadata.js",
      "returnType": "object"
    }
  ],
  "config": { "schema": {}, "defaults": {} },
  "runtime": { "language": "javascript", "sandbox": { "enabled": false } },
  "dependencies": {
    "npm": { "pdf-parse": "^1.1.1" }
  },
  "permissions": { "filesystem": ["/workspace/*", "./workspace/*", "/tmp/*"], "network": false, "shell": false, "envVars": [] },
  "metadata": { "tags": ["pdf", "documents", "extraction"], "category": "productivity", "icon": "file-text", "color": "#EF4444" }
}
