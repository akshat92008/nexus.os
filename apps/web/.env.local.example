# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API URLs — Sales API base (keep /api/sales suffix)
NEXT_PUBLIC_API_URL=http://localhost:3006/api/sales

# Nexus OS Core API — separate var, no fragile string replace
NEXT_PUBLIC_NEXUS_API_URL=http://localhost:3006/api

# Production examples:
# NEXT_PUBLIC_API_URL=https://your-nexus-api.run.app/api/sales
# NEXT_PUBLIC_NEXUS_API_URL=https://your-nexus-api.run.app/api
