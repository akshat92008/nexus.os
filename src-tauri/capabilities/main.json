{
  "$schema": "../gen/schemas/desktop-capability.json",
  "identifier": "main-capability",
  "description": "Core permissions for Nexus OS Nerve",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:allow-all",
    "fs:allow-all",
    "dialog:allow-all",
    "http:allow-all"
  ]
}
