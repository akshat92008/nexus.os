# =============================================================================
# Nexus OS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# ── Redis (Upstash free tier — https://upstash.com) ─────────────────────────
# Use the ioredis-compatible connection string from your Upstash dashboard.
# Format: rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# ── Supabase (free tier — https://supabase.com) ──────────────────────────────
# Found in: Supabase project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...   # service_role key (keep secret — server only)
SUPABASE_ANON_KEY=eyJhbGc...     # anon/public key (safe for frontend)

# ── LLM Providers (both free tier) ───────────────────────────────────────────
# OpenRouter — https://openrouter.ai (free models: deepseek, llama, mistral)
OPENROUTER_API_KEY=sk-or-v1-...

# Groq — https://console.groq.com (free tier, ultra-fast inference)
GROQ_API_KEY=gsk_...

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed frontend origins (no trailing slash)
# Production example: https://your-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Public URL of this API server (used for internal callbacks)
APP_URL=http://localhost:3001

# ── Optional ─────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Max parallel Groq calls through the rate limit governor (default: 4)
GROQ_GLOBAL_CONCURRENCY=4
